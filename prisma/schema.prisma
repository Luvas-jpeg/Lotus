generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model BotConfig {
  id              Int      @id @default(1)
  phone           String   @default("")
  managerPhone    String   @default("")
  systemPrompt    String   @default("")
  context         String   @default("")
  intervalMinutes Int      @default(10)
  temperature     Float    @default(0.6)
  mode            String   @default("reactive")
  active          Boolean  @default(false)
  nextRunAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Contact {
  id            Int            @id @default(autoincrement())
  phone         String         @unique
  name          String?
  conversations Conversation[]
  createdAt     DateTime       @default(now())
}

model Conversation {
  id            Int            @id @default(autoincrement())
  contactId     Int
  contact       Contact        @relation(fields: [contactId], references: [id])
  status        String         @default("bot")
  assignedTo    String?
  messages      Message[]
  handoffEvents HandoffEvent[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String
  text           String
  confidence     Float?
  needsHuman     Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

model HandoffEvent {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  reason         String
  status         String       @default("open")
  notifiedTo     String?
  createdAt      DateTime     @default(now())
  resolvedAt     DateTime?
}